// ============================================================================
// Firestore security rules for HOT POTATO · COMMAND CENTER PRO
// Paste into Firebase Console → Firestore Database → Rules → Publish.
//
// REQUIRES Firebase Authentication. Enable the Anonymous provider:
//   Console → Authentication → Sign-in method → Anonymous → Enable.
// The app calls signInAnonymously() on load, so every request carries a token.
// ============================================================================
//
// PRIVACY NOTE
// ------------
// Gating on `request.auth != null` with the **Anonymous** provider means a
// request must carry a Firebase token. That blocks unauthenticated/script
// abuse, enables Firebase quota/abuse protection, and is the foundation for
// per-user rules — BUT anyone can mint an anonymous token, so this is NOT full
// privacy. To restrict to your team, switch the sign-in flow to Google or Email
// link and gate by identity, e.g.:
//
//   match /projects/{pid} {
//     allow read, write: if request.auth != null
//                        && request.auth.token.email in ['you@studio.com'];
//   }
// ============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User roster: names readable for the login picker; credentials immutable.
    match /users/{uid} {
      allow read:   if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['name','pin','salt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() < 60
                    && request.resource.data.pin is string
                    && request.resource.data.salt is string;
      allow update, delete: if false;
    }

    // Project documents: one whole project's state each. Auth-gated + bounded.
    match /projects/{pid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && (request.resource == null
                       || (request.resource.data.size() < 900000
                           && request.resource.data.project is map));
    }

    // Legacy data from the old Command Center — read-only, for the importer.
    match /project/{id}       { allow read: if request.auth != null; allow write: if false; }
    match /contributions/{id} { allow read: if request.auth != null; allow write: if false; }
  }
}
