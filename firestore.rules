// ============================================================================
// Firestore security rules for HOT POTATO · COMMAND CENTER PRO
// Paste into Firebase Console → Firestore Database → Rules → Publish.
//
// REQUIRES the Google sign-in provider:
//   Console → Authentication → Sign-in method → Google → Enable.
// And the deploy domain authorised:
//   Console → Authentication → Settings → Authorized domains →
//   add  wildalchemists.github.io  (localhost is allowed by default).
// ============================================================================
//
// PRIVATE ACCESS
// --------------
// Only the Google accounts listed in ok() can read or write. This is the REAL
// security boundary. Keep the email list IDENTICAL to ALLOWED_EMAILS in
// index.html (the in-app list only controls UX; this is what enforces access).
//
// To add a teammate: add their lowercase Google email to BOTH lists.
// ============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function ok() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
             'pmartinpenarojo@gmail.com'
             // , 'teammate@studio.com'
           ];
    }

    // Project documents — one whole project's state each. Private + bounded.
    match /projects/{pid} {
      allow read:  if ok();
      allow write: if ok()
                   && (request.resource == null
                       || (request.resource.data.size() < 900000
                           && request.resource.data.project is map));
    }

    // Legacy data from the old Command Center — read-only, for the importer.
    match /project/{id}       { allow read: if ok(); allow write: if false; }
    match /contributions/{id} { allow read: if ok(); allow write: if false; }

    // Old PIN user roster — no longer used by the app.
    match /users/{id} { allow read, write: if false; }
  }
}
